# Copy to .env and adjust. PM2 loads these via python-dotenv in model_server.py and backend.py.

# --- Model server (qwen-model-server) ---
# Path to a local Qwen2.5-VL weights directory (or Hugging Face cache layout).
QWEN_MODEL_PATH=./Qwen2.5-VL-7B-Instruct
# Bind address for the VLM HTTP API (keep 127.0.0.1 if only the backend talks to it).
QWEN_HOST=127.0.0.1
QWEN_PORT=9127
# Sets CUDA_VISIBLE_DEVICES before torch starts (physical GPU index on the host).
QWEN_GPU_DEVICE=0
# Torch device inside the process; with QWEN_GPU_DEVICE=0 this is usually cuda:0.
QWEN_DEVICE=cuda:0

# --- Backend (qwen-backend) ---
BACKEND_HOST=0.0.0.0
BACKEND_PORT=9128
# Must match QWEN_HOST and QWEN_PORT above.
MODEL_SERVICE_URL=http://127.0.0.1:9127
MODEL_REQUEST_TIMEOUT=300

# --- Optional backend tuning (defaults exist in backend.py) ---
# CATEGORY_PROMPT=...
# FIGMA_MAX_JSON_BYTES=54525952
# FIGMA_SEMANTIC_MAX_CHUNKS=80
# FIGMA_CONVERT_TIMEOUT=900
# Per-request artifacts for POST /figma/convert-semantic-json (inputs, output, meta.json).
# FIGMA_SEMANTIC_RUNS_DIR=runs/figma_convert_semantic_json
# Downscale images before Qwen (longest side in px; 0 = off). Saved run inputs stay full-size.
# FIGMA_SEMANTIC_BANNER_MAX_EDGE=1536
# FIGMA_SEMANTIC_GRID_MAX_EDGE=1536
